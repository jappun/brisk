GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional comma-separated fallbacks when the primary model returns 503 / high demand
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash-lite
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=IEP Intake Companion <onboarding@resend.dev>

# Teacher email — must match your Resend signup email when using onboarding@resend.dev
TEACHER_EMAIL=you@example.com

# Comma-separated frontend URLs allowed to call this API (add your Vercel URL after deploy)
ALLOWED_ORIGINS=https://brisk-iep-intake.vercel.app
